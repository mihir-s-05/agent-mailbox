MAILBOX_ADDR=:8443
MAILBOX_BASE_PATH=/mcp
MAILBOX_DATABASE_URL=postgres://postgres:postgres@localhost:5432/agent_mailbox?sslmode=disable
MAILBOX_DEFAULT_POLL_MS=1200
MAILBOX_INACTIVITY_THRESHOLD=5m
MAILBOX_RETENTION_WINDOW=168h
MAILBOX_EXPIRY_SWEEP_INTERVAL=5m
MAILBOX_INACTIVITY_SWEEP_INTERVAL=30s
MAILBOX_RETENTION_SWEEP_INTERVAL=1h
MAILBOX_MAX_BODY_BYTES=32768
MAILBOX_MAX_ATTACHMENTS=8
MAILBOX_MAX_BROADCAST_RECIPIENTS=200
MAILBOX_MAILBOX_CAP=5000
MAILBOX_RATE_LIMIT_PER_MIN=60
MAILBOX_DEFAULT_TTL_SECONDS=604800
MAILBOX_MAX_TTL_SECONDS=2592000

MAILBOX_REQUIRE_MTLS=true
MAILBOX_TLS_CERT_FILE=certs/server.crt
MAILBOX_TLS_KEY_FILE=certs/server.key
MAILBOX_TLS_CLIENT_CA_FILE=certs/ca.crt
MAILBOX_TLS_CLIENT_CERT_FILE=certs/client.crt
MAILBOX_TLS_CLIENT_KEY_FILE=certs/client.key
MAILBOX_TLS_CLIENT_PFX_FILE=certs/client.pfx

MAILBOX_TOKENS_JSON_FILE=tokens.local.json
MAILBOX_BOOTSTRAP_TOKENS_FILE=tokens.local.secrets.json
MAILBOX_AUTO_GENERATE_TOKENS=true
MAILBOX_BOOTSTRAP_TEAM_ID=dev-team
MAILBOX_BOOTSTRAP_TOKEN_COUNT=2
MAILBOX_BOOTSTRAP_TOKEN_TTL=24h
MAILBOX_BOOTSTRAP_TOKEN_SCOPES=send:direct,poll:self,list:agents
MAILBOX_TOKEN_RELOAD_INTERVAL=15s
MAILBOX_ALLOW_PLAINTEXT_TOKENS=false
